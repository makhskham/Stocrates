# Required - Groq API key for LLM inference (Llama 3.3-70B)
# Get yours free at https://console.groq.com/
GROQ_API_KEY=gsk_your_key_here

# Optional - Polygon.io for intraday candles
POLYGON_API_KEY=

# Optional - Finnhub for market data and news
FINNHUB_API_KEY=

# Optional - NewsAPI for financial news
NEWS_API_KEY=
